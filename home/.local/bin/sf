#!/usr/bin/env bash

set -e

run_with_doppler() {
    LOG_LEVEL=warn doppler run --preserve-env --command="$*"
}

rspec() {
    run_with_doppler bin/rspec "$@"
}

start() {
    cd ~/Projects/secureframe
    make docker
    tmuxit --session "workin-hard" \
        "yarn && make frontend" \
        "h50%" "make bundle && make db_migrate && make server" \
        "50%" "make worker"
}

console() {
    run_with_doppler bin/rails console
}

db() {
    make psql
}

case "$1" in
    test)
        rspec "${@:2}"
        ;;
    start)
        start
        ;;
    console)
        console
        ;;
    db)
        db
        ;;
    *)
        echo "Usage: $0 {test}"
        exit 1
        ;;
esac
